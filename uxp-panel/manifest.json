{
  "id": "com.premierepro.mcp.transcript-uxp-bridge",
  "name": "MCP Transcript UXP Bridge",
  "shortname": "MCP Transcript",
  "version": "0.1.0",
  "main": "index.html",
  "host": {
    "app": "premierepro",
    "minVersion": "25.0.0"
  },
  "manifestVersion": 5,
  "requiredPermissions": {
    "network": {
      "domains": "all"
    }
  },
  "entrypoints": [
    {
      "id": "mcpTranscriptBridge",
      "type": "panel",
      "minimumSize": {
        "width": 320,
        "height": 320
      },
      "maximumSize": {
        "width": 1600,
        "height": 1600
      },
      "preferredDockedSize": {
        "width": 360,
        "height": 420
      },
      "preferredFloatingSize": {
        "width": 420,
        "height": 520
      },
      "label": {
        "default": "MCP Transcript Bridge"
      }
    }
  ]
}
